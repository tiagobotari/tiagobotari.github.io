---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  class: className = '',
  target,
  rel
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center px-6 py-3 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2';

const variantClasses = {
  primary: 'bg-primary-600 text-white hover:bg-primary-700 focus:ring-primary-600',
  secondary: 'bg-white text-primary-600 border-2 border-primary-600 hover:bg-primary-50 focus:ring-primary-600'
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className}`;

const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  class={classes}
  target={target}
  rel={rel}
>
  <slot />
</Element>
