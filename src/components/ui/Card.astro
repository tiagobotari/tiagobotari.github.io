---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;

const baseClasses = 'block p-6 bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300';
const classes = `${baseClasses} ${className}`;

const Element = href ? 'a' : 'div';
---

<Element href={href} class={classes}>
  <slot />
</Element>
