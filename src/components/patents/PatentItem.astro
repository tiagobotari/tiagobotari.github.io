---
import Badge from '../ui/Badge.astro';

interface Props {
  patent: {
    id: string;
    year: number;
    title: string;
    description: string;
    link: string;
    tags: string[];
  };
}

const { patent } = Astro.props;
---

<div class="patent-item py-6 border-b border-gray-200 last:border-0 space-y-3" data-tags={JSON.stringify(patent.tags)} data-year={patent.year}>
  <div class="space-y-2">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
      <h3 class="text-lg font-semibold text-near-black leading-tight flex-1">
        {patent.title}
      </h3>
      <a
        href={patent.link}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-primary-600 hover:text-primary-700 font-medium hover:underline whitespace-nowrap"
      >
        View Patent →
      </a>
    </div>

    <p class="text-sm text-gray-600 font-mono">
      {patent.id} · {patent.year}
    </p>

    <p class="text-gray-700 leading-relaxed">
      {patent.description}
    </p>
  </div>

  {patent.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {patent.tags.map((tag) => (
        <Badge>{tag}</Badge>
      ))}
    </div>
  )}
</div>
