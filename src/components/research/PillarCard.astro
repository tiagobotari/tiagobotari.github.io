---
import Badge from '../ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  keywords: string[];
}

const { title, description, keywords } = Astro.props;
---

<div class="p-6 bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 animate-on-scroll">
  <div class="space-y-4">
    <h3 class="text-2xl font-semibold text-near-black">
      {title}
    </h3>

    <p class="text-gray-700 leading-relaxed">
      {description}
    </p>

    <div class="pt-2">
      <div class="flex flex-wrap gap-2">
        {keywords.map((keyword) => (
          <Badge>{keyword}</Badge>
        ))}
      </div>
    </div>
  </div>
</div>
