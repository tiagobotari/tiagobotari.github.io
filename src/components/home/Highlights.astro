---
import Card from '../ui/Card.astro';
import publicationsData from '../../data/publications.json';
import patentsData from '../../data/patents.json';

const featuredPublications = publicationsData.publications.filter(p => p.featured);
const featuredPatents = patentsData.patents.filter(p => p.featured);
---

<section class="mx-auto max-w-content px-6 pt-4 pb-8 md:px-8 md:pt-6 md:pb-12">
  <div class="space-y-8">
    <div class="text-center space-y-2">
      <h2 class="text-3xl md:text-4xl font-bold text-near-black">
        Selected Highlights
      </h2>
      <p class="text-lg text-gray-600">
        Recent publications and patents in Scientific Machine Learning
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- Research Card -->
      <Card href="/research" class="animate-on-scroll">
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <h3 class="text-xl font-semibold text-near-black">Research</h3>
          </div>
          <p class="text-gray-600">
            Explore my research pillars in Scientific Machine Learning, interpretable AI, and data-driven discovery in physical sciences.
          </p>
        </div>
      </Card>

      <!-- Publications Card -->
      <Card href="/publications" class="animate-on-scroll">
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <h3 class="text-xl font-semibold text-near-black">Publications</h3>
          </div>
          <p class="text-gray-600">
            Browse my peer-reviewed publications in machine learning, materials science, and computational physics.
          </p>
        </div>
      </Card>

      <!-- Patents Card -->
      <Card href="/patents" class="animate-on-scroll md:col-span-2">
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <h3 class="text-xl font-semibold text-near-black">Patents</h3>
          </div>
          <p class="text-gray-600">
            View my patent portfolio covering ML-driven metrology, defect inspection, and image enhancement for semiconductor manufacturing.
          </p>
        </div>
      </Card>
    </div>

    <!-- Featured Items -->
    {(featuredPublications.length > 0 || featuredPatents.length > 0) && (
      <div class="space-y-8 pt-8 border-t border-gray-200">
        {featuredPublications.length > 0 && (
          <div class="space-y-4 animate-on-scroll">
            <h3 class="text-xl font-semibold text-near-black">Featured Publications</h3>
            <div class="space-y-3">
              {featuredPublications.map(pub => (
                <div class="p-4 bg-gray-50 rounded-lg">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                    <div class="flex-1">
                      <h4 class="font-medium text-near-black">{pub.title}</h4>
                      <p class="text-sm text-gray-600 mt-1">{pub.venue}, {pub.year}</p>
                    </div>
                    {pub.links.doi && (
                      <a
                        href={pub.links.doi}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm text-primary-600 hover:text-primary-700 font-medium"
                      >
                        View →
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {featuredPatents.length > 0 && (
          <div class="space-y-4 animate-on-scroll">
            <h3 class="text-xl font-semibold text-near-black">Featured Patents</h3>
            <div class="space-y-3">
              {featuredPatents.map(patent => (
                <div class="p-4 bg-gray-50 rounded-lg">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                    <div class="flex-1">
                      <h4 class="font-medium text-near-black">{patent.title}</h4>
                      <p class="text-sm text-gray-600 mt-1">{patent.id} · {patent.year}</p>
                    </div>
                    <a
                      href={patent.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-primary-600 hover:text-primary-700 font-medium"
                    >
                      View →
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>
