---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout
  title="CV - Tiago Botari"
  description="Curriculum Vitae of Tiago Botari, Senior Researcher in Scientific Machine Learning at ASML Research."
>
  <div class="mx-auto max-w-content px-6 py-8 md:px-8 md:py-12">
    <!-- Page Header -->
    <div class="text-center space-y-3 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-near-black">
        Curriculum Vitae
      </h1>
      <div>
        <Button href="/pdfs/Tiago_Botari_CV.pdf" variant="primary" target="_blank" rel="noopener noreferrer">
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Download Full CV (PDF)
        </Button>
      </div>
    </div>

    <!-- CV Content -->
    <div class="prose prose-lg max-w-none">
      <!-- Professional Experience -->
      <section class="mb-8">
        <h2 class="text-3xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
          Professional Experience
        </h2>

        <div class="space-y-6">
          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-2">
              <div>
                <h3 class="text-xl font-semibold text-near-black">Senior Researcher, Scientific Machine Learning</h3>
                <p class="text-lg text-gray-700">ASML Research</p>
              </div>
              <p class="text-gray-600 sm:text-right">2022 – Present</p>
            </div>
            <ul class="list-disc list-inside text-gray-700 space-y-2 mt-3">
              <li>Develop physics-informed and hybrid machine learning models for semiconductor metrology and defect inspection</li>
              <li>Lead research on interpretable AI and uncertainty quantification for high-stakes industrial applications</li>
              <li>Combine computational simulations with experimental data to solve inverse problems in semiconductor manufacturing</li>
              <li>Co-supervise MSc and PhD students in collaboration with Dutch universities</li>
              <li>Author of multiple patents in ML-driven metrology and image enhancement</li>
            </ul>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-2">
              <div>
                <h3 class="text-xl font-semibold text-near-black">Postdoctoral Researcher</h3>
                <p class="text-lg text-gray-700">Computational Materials Science</p>
              </div>
              <p class="text-gray-600 sm:text-right">2019 – 2022</p>
            </div>
            <ul class="list-disc list-inside text-gray-700 space-y-2 mt-3">
              <li>Applied machine learning to materials discovery and property prediction</li>
              <li>Developed interpretable models for composition-property relationships in glass materials</li>
              <li>Published research in top materials science and machine learning journals</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Education -->
      <section class="mb-8">
        <h2 class="text-3xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
          Education
        </h2>

        <div class="space-y-6">
          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-2">
              <div>
                <h3 class="text-xl font-semibold text-near-black">PhD in Computational Physics</h3>
                <p class="text-lg text-gray-700">University (Details TBD)</p>
              </div>
              <p class="text-gray-600 sm:text-right">Year</p>
            </div>
            <p class="text-gray-700 mt-2">
              Dissertation focused on computational methods in condensed matter physics and materials science
            </p>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-2">
              <div>
                <h3 class="text-xl font-semibold text-near-black">MSc in Physics</h3>
                <p class="text-lg text-gray-700">University (Details TBD)</p>
              </div>
              <p class="text-gray-600 sm:text-right">Year</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Research Interests -->
      <section class="mb-8">
        <h2 class="text-3xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
          Research Interests
        </h2>

        <ul class="grid sm:grid-cols-2 gap-3 text-gray-700">
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Physics-Informed Machine Learning</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Uncertainty Quantification</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Interpretable & Trustworthy AI</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Semiconductor Metrology</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Defect Inspection</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Computational Materials Science</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Hybrid Modeling</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>Inverse Problems</span>
          </li>
        </ul>
      </section>

      <!-- Skills -->
      <section class="mb-8">
        <h2 class="text-3xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
          Technical Skills
        </h2>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-semibold text-near-black mb-3">Machine Learning</h3>
            <ul class="text-gray-700 space-y-1">
              <li>Neural Networks & Deep Learning</li>
              <li>Physics-Informed Neural Networks</li>
              <li>Uncertainty Quantification</li>
              <li>Model Interpretability</li>
              <li>Computer Vision</li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl font-semibold text-near-black mb-3">Scientific Computing</h3>
            <ul class="text-gray-700 space-y-1">
              <li>Python (PyTorch, TensorFlow, NumPy)</li>
              <li>Computational Physics</li>
              <li>Molecular Dynamics</li>
              <li>Density Functional Theory</li>
              <li>High-Performance Computing</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Selected Achievements -->
      <section class="mb-8">
        <h2 class="text-3xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
          Selected Achievements
        </h2>

        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-600 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
