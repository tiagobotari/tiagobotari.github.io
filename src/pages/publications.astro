---
import PageLayout from '../layouts/PageLayout.astro';
import PublicationItem from '../components/publications/PublicationItem.astro';
import publicationsData from '../data/publications.json';

// Sort publications by year (descending)
const sortedPublications = [...publicationsData.publications].sort((a, b) => b.year - a.year);

// Get unique years and tags for filters
const years = [...new Set(sortedPublications.map(p => p.year))].sort((a, b) => b - a);
const allTags = [...new Set(sortedPublications.flatMap(p => p.tags))].sort();

// Group publications by year
const publicationsByYear = sortedPublications.reduce((acc, pub) => {
  if (!acc[pub.year]) {
    acc[pub.year] = [];
  }
  acc[pub.year].push(pub);
  return acc;
}, {} as Record<number, typeof sortedPublications>);
---

<PageLayout
  title="Publications - Tiago Botari"
  description="Browse my publications in machine learning, materials science, computational physics, and semiconductor metrology."
>
  <div class="mx-auto max-w-content px-6 py-8 md:px-8 md:py-12">
    <!-- Page Header -->
    <div class="text-center space-y-3 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-near-black">
        Publications
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Peer-reviewed publications in machine learning, materials science, and computational physics
      </p>
    </div>

    <!-- Search and Filter Bar -->
    <div class="mb-8 space-y-4">
      <!-- Search -->
      <div class="relative">
        <input
          type="search"
          id="search-input"
          placeholder="Search by title, author, or venue..."
          class="w-full px-4 py-3 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
          aria-label="Search publications"
        />
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap gap-4">
        <!-- Year Filter -->
        <div>
          <label for="year-filter" class="block text-sm font-medium text-gray-700 mb-1">Year</label>
          <select
            id="year-filter"
            class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
          >
            <option value="">All years</option>
            {years.map(year => (
              <option value={year}>{year}</option>
            ))}
          </select>
        </div>

        <!-- Tag Filter -->
        <div>
          <label for="tag-filter" class="block text-sm font-medium text-gray-700 mb-1">Topic</label>
          <select
            id="tag-filter"
            class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
          >
            <option value="">All topics</option>
            {allTags.map(tag => (
              <option value={tag}>{tag}</option>
            ))}
          </select>
        </div>

        <!-- Reset Button -->
        <div class="flex items-end">
          <button
            id="reset-filters"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
          >
            Reset
          </button>
        </div>
      </div>
    </div>

    <!-- Results Count -->
    <div class="mb-6">
      <p id="results-count" class="text-sm text-gray-600">
        Showing {sortedPublications.length} publications
      </p>
    </div>

    <!-- Publications List -->
    <div id="publications-list" class="space-y-8">
      {years.map(year => (
        <div class="year-group" data-year={year}>
          <h2 class="text-2xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
            {year}
          </h2>
          <div class="space-y-0">
            {publicationsByYear[year].map(pub => (
              <PublicationItem publication={pub} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- No Results Message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-lg text-gray-600">No publications found matching your criteria.</p>
      <button
        id="no-results-reset"
        class="mt-4 text-primary-600 hover:text-primary-700 font-medium"
      >
        Reset filters
      </button>
    </div>
  </div>
</PageLayout>

<script>
  // Search and filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const yearFilter = document.getElementById('year-filter') as HTMLSelectElement;
    const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement;
    const resetButton = document.getElementById('reset-filters') as HTMLButtonElement;
    const noResultsReset = document.getElementById('no-results-reset') as HTMLButtonElement;
    const publicationsList = document.getElementById('publications-list');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');

    function filterPublications() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedYear = yearFilter.value;
      const selectedTag = tagFilter.value;

      let visibleCount = 0;
      const yearGroups = document.querySelectorAll('.year-group');

      yearGroups.forEach((yearGroup) => {
        const yearGroupElement = yearGroup as HTMLElement;
        const items = yearGroup.querySelectorAll('.publication-item');
        let yearHasVisible = false;

        items.forEach((item) => {
          const itemElement = item as HTMLElement;
          const title = itemElement.querySelector('h3')?.textContent?.toLowerCase() || '';
          const authors = itemElement.querySelector('p')?.textContent?.toLowerCase() || '';
          const venue = itemElement.querySelectorAll('p')[1]?.textContent?.toLowerCase() || '';
          const year = itemElement.dataset.year || '';
          const tags = JSON.parse(itemElement.dataset.tags || '[]');

          const matchesSearch = !searchTerm ||
            title.includes(searchTerm) ||
            authors.includes(searchTerm) ||
            venue.includes(searchTerm);

          const matchesYear = !selectedYear || year === selectedYear;
          const matchesTag = !selectedTag || tags.includes(selectedTag);

          if (matchesSearch && matchesYear && matchesTag) {
            itemElement.style.display = '';
            visibleCount++;
            yearHasVisible = true;
          } else {
            itemElement.style.display = 'none';
          }
        });

        yearGroupElement.style.display = yearHasVisible ? '' : 'none';
      });

      // Update results count
      if (resultsCount) {
        resultsCount.textContent = `Showing ${visibleCount} publication${visibleCount !== 1 ? 's' : ''}`;
      }

      // Show/hide no results message
      if (publicationsList && noResults) {
        if (visibleCount === 0) {
          publicationsList.style.display = 'none';
          noResults.classList.remove('hidden');
        } else {
          publicationsList.style.display = '';
          noResults.classList.add('hidden');
        }
      }
    }

    function resetFilters() {
      searchInput.value = '';
      yearFilter.value = '';
      tagFilter.value = '';
      filterPublications();
    }

    // Event listeners
    searchInput?.addEventListener('input', filterPublications);
    yearFilter?.addEventListener('change', filterPublications);
    tagFilter?.addEventListener('change', filterPublications);
    resetButton?.addEventListener('click', resetFilters);
    noResultsReset?.addEventListener('click', resetFilters);
  });
</script>
</PageLayout>
