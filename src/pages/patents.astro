---
import PageLayout from '../layouts/PageLayout.astro';
import PatentItem from '../components/patents/PatentItem.astro';
import patentsData from '../data/patents.json';

// Sort patents by year (descending)
const sortedPatents = [...patentsData.patents].sort((a, b) => b.year - a.year);

// Get unique tags for filters
const allTags = [...new Set(sortedPatents.flatMap(p => p.tags))].sort();

// Group patents by year
const patentsByYear = sortedPatents.reduce((acc, patent) => {
  if (!acc[patent.year]) {
    acc[patent.year] = [];
  }
  acc[patent.year].push(patent);
  return acc;
}, {} as Record<number, typeof sortedPatents>);
---

<PageLayout
  title="Patents - Tiago Botari"
  description="My patent portfolio covering machine learning applications in semiconductor metrology, defect inspection, and image enhancement."
>
  <div class="mx-auto max-w-content px-6 py-8 md:px-8 md:py-12">
    <!-- Page Header -->
    <div class="text-center space-y-3 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-near-black">
        Patents
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Machine learning innovations for semiconductor metrology, defect inspection, and image enhancement
      </p>
    </div>

    <!-- Filter Bar -->
    <div class="mb-8 flex flex-wrap items-end gap-4">
      <!-- Tag Filter -->
      <div class="flex-1 min-w-[200px]">
        <label for="tag-filter" class="block text-sm font-medium text-gray-700 mb-1">Filter by Topic</label>
        <select
          id="tag-filter"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
        >
          <option value="">All topics</option>
          {allTags.map(tag => (
            <option value={tag}>{tag}</option>
          ))}
        </select>
      </div>

      <!-- Reset Button -->
      <div>
        <button
          id="reset-filters"
          class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
        >
          Reset
        </button>
      </div>
    </div>

    <!-- Results Count -->
    <div class="mb-6">
      <p id="results-count" class="text-sm text-gray-600">
        Showing {sortedPatents.length} patents
      </p>
    </div>

    <!-- Patents List -->
    <div id="patents-list" class="space-y-8">
      {Object.entries(patentsByYear).map(([year, patents]) => (
        <div class="year-group" data-year={year}>
          <h2 class="text-2xl font-bold text-near-black mb-6 pb-2 border-b-2 border-primary-600">
            {year}
          </h2>
          <div class="space-y-0">
            {patents.map(patent => (
              <PatentItem patent={patent} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- No Results Message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-lg text-gray-600">No patents found matching your criteria.</p>
      <button
        id="no-results-reset"
        class="mt-4 text-primary-600 hover:text-primary-700 font-medium"
      >
        Reset filters
      </button>
    </div>
  </div>
</PageLayout>

<script>
  // Filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement;
    const resetButton = document.getElementById('reset-filters') as HTMLButtonElement;
    const noResultsReset = document.getElementById('no-results-reset') as HTMLButtonElement;
    const patentsList = document.getElementById('patents-list');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');

    function filterPatents() {
      const selectedTag = tagFilter.value;

      let visibleCount = 0;
      const yearGroups = document.querySelectorAll('.year-group');

      yearGroups.forEach((yearGroup) => {
        const yearGroupElement = yearGroup as HTMLElement;
        const items = yearGroup.querySelectorAll('.patent-item');
        let yearHasVisible = false;

        items.forEach((item) => {
          const itemElement = item as HTMLElement;
          const tags = JSON.parse(itemElement.dataset.tags || '[]');

          const matchesTag = !selectedTag || tags.includes(selectedTag);

          if (matchesTag) {
            itemElement.style.display = '';
            visibleCount++;
            yearHasVisible = true;
          } else {
            itemElement.style.display = 'none';
          }
        });

        yearGroupElement.style.display = yearHasVisible ? '' : 'none';
      });

      // Update results count
      if (resultsCount) {
        resultsCount.textContent = `Showing ${visibleCount} patent${visibleCount !== 1 ? 's' : ''}`;
      }

      // Show/hide no results message
      if (patentsList && noResults) {
        if (visibleCount === 0) {
          patentsList.style.display = 'none';
          noResults.classList.remove('hidden');
        } else {
          patentsList.style.display = '';
          noResults.classList.add('hidden');
        }
      }
    }

    function resetFilters() {
      tagFilter.value = '';
      filterPatents();
    }

    // Event listeners
    tagFilter?.addEventListener('change', filterPatents);
    resetButton?.addEventListener('click', resetFilters);
    noResultsReset?.addEventListener('click', resetFilters);
  });
</script>
</PageLayout>
