---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/Card.astro';
import socialData from '../data/social.json';
---

<PageLayout
  title="Contact - Tiago Botari"
  description="Get in touch with Tiago Botari for collaboration opportunities, research inquiries, or general questions."
>
  <div class="mx-auto max-w-content px-6 py-8 md:px-8 md:py-12">
    <!-- Page Header -->
    <div class="text-center space-y-3 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-near-black">
        Contact
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Feel free to reach out for collaboration opportunities, research inquiries, or general questions
      </p>
    </div>

    <!-- Contact Information -->
    <div class="max-w-2xl mx-auto space-y-8">
      <!-- Email -->
      <Card class="text-center">
        <div class="space-y-4">
          <div class="flex justify-center">
            <div class="p-4 bg-primary-100 rounded-full">
              <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-near-black mb-2">Email</h2>
            <a
              href={`mailto:${socialData.email}`}
              class="text-primary-600 hover:text-primary-700 font-medium hover:underline"
            >
              {socialData.email}
            </a>
          </div>
        </div>
      </Card>

      <!-- Social Links -->
      <div class="text-center space-y-6">
        <h2 class="text-2xl font-semibold text-near-black">
          Connect with me
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <!-- Google Scholar -->
          <Card href={socialData.scholar} class="hover:border-primary-300">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-gray-100 rounded-lg">
                <svg class="w-6 h-6 text-gray-700" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8.978 8.978 0 0 1 12 9a8.978 8.978 0 0 1 7.162 4.44L24 9.5z"/>
                </svg>
              </div>
              <div class="text-left flex-1">
                <h3 class="font-semibold text-near-black">Google Scholar</h3>
                <p class="text-sm text-gray-600">View publications & citations</p>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </Card>

          <!-- ORCID -->
          <Card href={socialData.orcid} class="hover:border-primary-300">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-gray-100 rounded-lg">
                <svg class="w-6 h-6 text-gray-700" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 4.053-1.766 4.053-3.722 0-2.025-1.694-3.722-4.053-3.722h-2.297z"/>
                </svg>
              </div>
              <div class="text-left flex-1">
                <h3 class="font-semibold text-near-black">ORCID</h3>
                <p class="text-sm text-gray-600">Research profile & works</p>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </Card>

          <!-- LinkedIn -->
          <Card href={socialData.linkedin} class="hover:border-primary-300">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-gray-100 rounded-lg">
                <svg class="w-6 h-6 text-gray-700" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div class="text-left flex-1">
                <h3 class="font-semibold text-near-black">LinkedIn</h3>
                <p class="text-sm text-gray-600">Professional network</p>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </Card>

          <!-- GitHub -->
          <Card href={socialData.github} class="hover:border-primary-300">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-gray-100 rounded-lg">
                <svg class="w-6 h-6 text-gray-700" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </div>
              <div class="text-left flex-1">
                <h3 class="font-semibold text-near-black">GitHub</h3>
                <p class="text-sm text-gray-600">Code & projects</p>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </Card>
        </div>
      </div>

      <!-- Additional Info -->
      <div class="text-center pt-8 border-t border-gray-200">
        <p class="text-gray-600 leading-relaxed max-w-lg mx-auto">
          I'm always interested in discussing new research opportunities, potential collaborations, or industrial partnerships at the intersection of machine learning and physical sciences.
        </p>
      </div>
    </div>
  </div>
</PageLayout>
